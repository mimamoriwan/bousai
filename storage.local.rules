rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isGoogleUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isSafeImage(maxSize) {
      return request.resource.size <= maxSize
        && request.resource.contentType.matches('image/.*');
    }

    match /map_pins/{uid}/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(uid) && isSafeImage(5 * 1024 * 1024);
      allow delete: if isOwner(uid);
    }

    match /user_photos/{fileName} {
      allow read: if true;
      allow create, update: if isGoogleUser()
        && fileName.matches(request.auth.uid + '_.*')
        && isSafeImage(3 * 1024 * 1024);
      allow delete: if isGoogleUser()
        && fileName.matches(request.auth.uid + '_.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
